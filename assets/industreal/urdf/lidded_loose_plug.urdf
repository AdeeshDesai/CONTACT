<?xml version="1.0"?>
<robot name="power_plug">
    <link name="power_plug">
        <visual>
            <geometry>
                <mesh filename="../mesh/contact_mesh/lidded_loose_plug.obj"/>
            </geometry>
            <material name="Black">
                <color rgba="0 0 0 1"/>
            </material>
        </visual>
        <collision>
            <geometry>
                <mesh filename="../mesh/contact_mesh/lidded_loose_plug.obj"/>
            </geometry>
            <sdf resolution="128"/>
        </collision>
    </link>
</robot>
